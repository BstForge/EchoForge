<Fluent:RibbonWindow x:Class="EchoForge.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:local="clr-namespace:EchoForge"
                     xmlns:Fluent="urn:fluent-ribbon"
                     mc:Ignorable="d"
                     Title="EchoForge"
                     Height="450"
                     Width="800">
    <DockPanel>
        <Fluent:Ribbon x:Name="MainRibbon" DockPanel.Dock="Top">
            <Fluent:RibbonTabItem Header="File">
                <Fluent:RibbonGroupBox Header="Project">
                    <Fluent:Button Header="New Project" />
                    <Fluent:Button Header="Open Project" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Settings">
                    <Fluent:Button Header="API Keys" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
            <Fluent:RibbonTabItem Header="Tools">
                <Fluent:RibbonGroupBox Header="Actions">
                    <Fluent:Button Header="Parse Scene" />
                    <Fluent:Button Header="Generate Audio" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>
        </Fluent:Ribbon>
        <Grid>
            <!-- Future content like scene previews and output logs -->
        </Grid>
    </DockPanel>
</Fluent:RibbonWindow>